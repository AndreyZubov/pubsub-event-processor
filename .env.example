# Copy to .env and fill in real values. .env is gitignored.

# --- Salesforce OAuth ---
# Connected App credentials for client-credentials or JWT bearer flow
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com

# --- Subscription ---
# Comma-separated list of Pub/Sub topics (Platform Events or CDC channels)
# Example: /event/Order_Event__e,/data/AccountChangeEvent
SF_TOPICS=/event/Order_Event__e
PUBSUB_ENDPOINT=api.pubsub.salesforce.com:7443

# --- Storage ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pubsub?sslmode=disable

# --- Downstream sink (optional) ---
# Leave empty to use the in-process channel sink
SINK_WEBHOOK_URL=

# --- Runtime tuning ---
WORKER_COUNT=8
FLOW_BATCH_SIZE=100

# --- Admin HTTP server ---
HTTP_ADDR=:8080

# --- Logging ---
# Levels: debug, info, warn, error
LOG_LEVEL=info
